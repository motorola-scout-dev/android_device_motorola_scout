get_prop(vendor_init, vendor_mot_prop)
set_prop(vendor_init, vendor_mot_prop)
get_prop(vendor_init, vendor_nfc_prop)
set_prop(vendor_init, vendor_nfc_prop)
rw_dir_file(vendor_init, sysfs_leds)
rw_dir_file(vendor_init, sysfs_ged)
rw_dir_file(vendor_init, sysfs_power_supply)
get_prop(vendor_init, vendor_sku_prop)
set_prop(vendor_init, vendor_sku_prop)
set_prop(vendor_init, system_mot_prop)
set_prop(vendor_init, vendor_bluetooth_prop)
set_prop(vendor_init, vendor_gpu_prop)
# dontaudit vendor_init vendor_mtk_rcs_prop:property_service set;
set_prop(vendor_init, vendor_mtk_vendor_vt_prop)


allow vendor_init vendor_userdir_file:dir { getattr search };
allow vendor_init self:perf_event cpu;




# dontaudit vendor_init build_prop:property_service set;
# dontaudit vendor_init default_prop:property_service set;

# dontaudit vendor_init default_prop:file { read open };# Silence binder/servicemanager noise
# dontaudit vendor_init servicemanager:binder { call transfer };

dontaudit vendor_init userdebug_or_eng_prop:property_service set;
dontaudit vendor_init build_prop:property_service set;
dontaudit vendor_init vendor_userdir_file:dir { write add_name };

# Camera property set
set_prop(vendor_init, vendor_mot_camera_prop)

# Silence harmless Motorola init.rc property reads
dontaudit vendor_init default_prop:file r_file_perms;
dontaudit vendor_init default_prop:property_service set;
dontaudit vendor_init vts_status_prop:file r_file_perms;
