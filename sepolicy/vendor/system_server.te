get_prop(system_server, vendor_mot_prop)
allow system_server vendor_sysfs_otg:file { getattr open read };
allow system_server hal_graphics_allocator_default_tmpfs:file rw_file_perms;
# Removed broad property and sysfs access silencers.
get_prop(system_server, vendor_gpu_prop)
allow system_server zygote_tmpfs:file w_file_perms;

# Silence harmless vendor property and sysfs reads
dontaudit system_server vendor_default_prop:file r_file_perms;
dontaudit system_server sysfs:file r_file_perms;
