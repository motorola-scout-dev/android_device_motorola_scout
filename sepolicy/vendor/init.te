r_dir_file(init, sysfs_batteryinfo)
allow init sysfs_power_supply:file { setattr };
get_prop(init, vendor_mot_prop)
set_prop(init, vendor_mot_prop)

allow init mnt_product_file:dir mounton;
allow init functionfs:dir mounton;

# dontaudit init sysfs:file { open write };
