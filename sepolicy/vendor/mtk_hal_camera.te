allow mtk_hal_camera vendor_persist_camera_file:dir r_dir_perms;
allow mtk_hal_camera vendor_persist_camera_file:file rw_file_perms;
allow mtk_hal_camera vendor_camera_data_file:dir rw_dir_perms;
allow mtk_hal_camera vendor_camera_data_file:dir create_dir_perms;
allow mtk_hal_camera vendor_camera_data_file:sock_file write;
allow mtk_hal_camera vendor_camera_data_file:file create_file_perms;
allow mtk_hal_camera vendor_imager_data_file:dir rw_dir_perms;
allow mtk_hal_camera vendor_imager_data_file:file rw_file_perms;
allow mtk_hal_camera vendor_imager_data_file:file { create setattr };
allow mtk_hal_camera vendor_imager_metadata_file:dir rw_dir_perms;
allow mtk_hal_camera vendor_imager_metadata_file:file rw_file_perms;
allow mtk_hal_camera vendor_imager_metadata_file:file { create setattr };
allow mtk_hal_camera sysfs_therm:dir r_dir_perms;
allow mtk_hal_camera sysfs_therm:file r_file_perms;
allow mtk_hal_camera proc_cpu_loading:file r_file_perms;
r_dir_file(mtk_hal_camera, persist_data_file)
get_prop(mtk_hal_camera, vendor_mot_prop)
get_prop(mtk_hal_camera, system_mot_camera_prop)
get_prop(mtk_hal_camera, vendor_mot_camera_prop)
set_prop(mtk_hal_camera, vendor_mot_camera_prop)
get_prop(mtk_hal_camera, vendor_persist_camera_prop)
allow mtk_hal_camera motcamera_app:binder { call transfer };
allow mtk_hal_camera motcamera_app:fd use;

allow mtk_hal_camera sysfs_power_supply:dir r_dir_perms;
allow mtk_hal_camera sysfs_power_supply:file r_file_perms;

allow mtk_hal_camera hal_graphics_allocator_default_tmpfs:file rw_file_perms;
allow mtk_hal_camera mtk_hal_mali_platform_default_service:service_manager find;
get_prop(mtk_hal_camera, camera_config_prop)
get_prop(mtk_hal_camera, vendor_gpu_prop)

# Silence default_prop read noise
dontaudit mtk_hal_camera default_prop:file r_file_perms;

# cybert logcat additions
allow mtk_hal_camera system_data_file:dir search;

# Allow camera HAL to register its vendor services
allow mtk_hal_camera mtk_hal_camera_bgservice:service_manager { add find };
allow mtk_hal_camera mtk_hal_camera_atms_service:service_manager { add find };
allow mtk_hal_camera mtk_hal_camera_aovservice:service_manager { add find };
