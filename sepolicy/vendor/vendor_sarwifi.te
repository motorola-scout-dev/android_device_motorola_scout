# Motorola SAR WiFi Service
type vendor_sarwifi, domain;
type vendor_sarwifi_exec, exec_type, vendor_file_type, file_type;

init_daemon_domain(vendor_sarwifi)

binder_use(vendor_sarwifi)
allow vendor_sarwifi servicemanager:binder { call transfer };

# Read Motorola vendor properties
get_prop(vendor_sarwifi, vendor_mot_prop)
