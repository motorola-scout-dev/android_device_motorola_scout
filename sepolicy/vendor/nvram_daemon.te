get_prop(nvram_daemon, vendor_mot_prop)
binder_use(nvram_daemon)
binder_call(nvram_daemon, servicemanager)
dontaudit nvram_daemon vendor_default_prop:property_service set;
add_service(nvram_daemon, mtk_hal_nvram_service)
# CCCI
allow nvram_daemon sysfs_ccci:dir r_dir_perms;
allow nvram_daemon sysfs_ccci:file r_file_perms;

allow nvram_daemon gsm0710muxd_device:chr_file { ioctl open read write };
allow nvram_daemon nvcfg_file:dir search;

