type hal_dms_default, domain;
type hal_dms_default_exec, exec_type, vendor_file_type, file_type;

init_daemon_domain(hal_dms_default)

# Allow HwBinder IPC
hwbinder_use(hal_dms_default)
get_prop(hal_dms_default, hwservicemanager_prop)
allow hal_dms_default hidl_base_hwservice:hwservice_manager add;
allow hal_dms_default servicemanager:binder { call transfer };

# Dolby service binder and heap access
vndbinder_use(hal_dms_default)
hal_client_domain(hal_dms_default, hal_codec2)
allow hal_dms_default dmabuf_system_heap_device:chr_file r_file_perms;

# Allow access to audio devices and properties
# Properties
get_prop(hal_dms_default, vendor_audio_prop)
add_service(hal_dms_default, hal_dms_service)