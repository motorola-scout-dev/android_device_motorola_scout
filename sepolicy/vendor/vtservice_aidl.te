type vtservice_aidl, domain;
type vtservice_aidl_exec, exec_type, vendor_file_type, file_type;

init_daemon_domain(vtservice_aidl)

# Allow vtservice_aidl to perform necessary operations
allow vtservice_aidl self:capability { net_admin net_raw };
allow vtservice_aidl self:udp_socket create_socket_perms_no_ioctl;
allow vtservice_aidl fwmarkd_socket:sock_file write;
allow vtservice_aidl netd:unix_stream_socket connectto;

allow vtservice_aidl servicemanager:binder { call transfer };
add_service(vtservice_aidl, hal_vtservice_aidl_service)